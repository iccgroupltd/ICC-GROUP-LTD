---
/**
 * Long contact form to get details about a customer's claim.
 *
 * See https://cosmicthemes.com/docs/contact-form/ for more information on how to set up a contact form
 *
 * Form inputs are styled inline below (pill style) for the contact page.
 * The global "form__input" class is still used elsewhere (e.g. newsletter).
 */

// components
import Button from "@components/Button/Button.astro";

const inputClass =
  "h-12 w-full rounded-full border border-base-200 bg-transparent pl-5 text-lg font-normal text-base-600 outline-none transition focus:border-primary-500 focus:ring-2 focus:ring-primary-500/30 dark:border-base-700 dark:bg-base-900 dark:text-base-200";

const textareaClass =
  "w-full rounded-2xl border border-base-200 bg-transparent p-4 text-lg font-normal text-base-600 outline-none transition focus:border-primary-500 focus:ring-2 focus:ring-primary-500/30 dark:border-base-700 dark:bg-base-900 dark:text-base-200";
---

<section id="contact" class="mx-auto w-full">
  <form
    id="g51sSupfB"
    name="contact"
    action="https://api.web3forms.com/submit"
    method="POST"
    class="flex flex-col gap-5"
  >
    <input type="hidden" name="access_key" value="6fdf4158-a8dd-411e-b872-c482fe3e6170" />
    <input type="hidden" name="subject" value="New contact form submission — Taxi site" />
    <input type="hidden" name="from_name" value="Taxi website" />
    <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />
    <div>
      <div class="grid gap-5 sm:grid-cols-2">
        <div class="flex flex-col">
          <label for="contact-fname" class="form__label sr-only"
            >First Name <span class="text-red-600">*</span></label
          >
          <input
            type="text"
            class={inputClass}
            name="fname"
            id="contact-fname"
            placeholder="First name"
            required
          />
        </div>

        <div class="flex flex-col">
          <label for="contact-lname" class="form__label sr-only"
            >Last Name <span class="text-red-600">*</span></label
          >
          <input
            type="text"
            class={inputClass}
            name="lname"
            id="contact-lname"
            placeholder="Last name"
            required
          />
        </div>
      </div>
    </div>
    <div>
      <label for="contact-address" class="form__label sr-only mb-1"
        >Street Address <span class="text-red-600">*</span></label
      >
      <input
        type="text"
        class={inputClass}
        name="address"
        id="contact-address"
        placeholder="Street address"
        required
      />
    </div>
    <div>
      <div class="grid gap-5 sm:grid-cols-3">
        <div class="flex flex-col">
          <label for="contact-city" class="form__label sr-only"
            >City <span class="text-red-600">*</span></label
          >
          <input
            type="text"
            class={inputClass}
            name="city"
            id="contact-city"
            placeholder="City"
            required
          />
        </div>

        <div class="flex flex-col">
          <label for="contact-state" class="form__label sr-only"
            >County <span class="text-red-600">*</span></label
          >
          <input
            type="text"
            class={inputClass}
            name="state"
            id="contact-state"
            placeholder="County"
            required
          />
        </div>

        <div class="flex flex-col">
          <label for="contact-zip" class="form__label sr-only"
            >Postcode <span class="text-red-600">*</span></label
          >
          <input
            type="text"
            class={inputClass}
            name="zip"
            id="contact-zip"
            placeholder="Postcode"
            required
          />
        </div>
      </div>
    </div>
    <div>
      <label for="contact-email" class="form__label sr-only mb-1"
        >Email <span class="text-red-600">*</span></label
      >
      <input
        type="email"
        class={inputClass}
        name="email"
        id="contact-email"
        inputmode="email"
        placeholder="Preferred contact email"
        required
      />
    </div>
    <div>
      <label for="contact-phone" class="form__label sr-only mb-1"
        >Phone Number <span class="text-red-600">*</span></label
      >
      <input
        type="tel"
        class={inputClass}
        name="phone"
        id="contact-phone"
        inputmode="tel"
        placeholder="Phone number"
        required
      />
    </div>
    <div>
      <label for="contact-timeframe" class="form__label sr-only mb-1"
        >Desired Time Frame <span class="text-red-600">*</span></label
      >
      <input
        type="text"
        class={inputClass}
        name="timeframe"
        id="contact-timeframe"
        placeholder="Desired time frame for the work to be completed"
        required
      />
    </div>
    <div>
      <label for="contact-services" class="form__label sr-only mb-1"
        >Services Desired <span class="text-red-600">*</span></label
      >
      <textarea
        name="services"
        class={textareaClass}
        id="contact-services"
        rows="4"
        placeholder="Please provide a brief description of the services desired"
        required></textarea>
    </div>
    <Button variant="primary" type="submit" class="h-12 w-full rounded-full">Submit</Button>
  </form>
  <div
    id="contact-status"
    role="status"
    aria-live="polite"
    class="mt-4 hidden rounded-2xl p-4 text-center text-lg font-medium"
  >
  </div>
</section>

<script is:inline>
  const form = document.getElementById("g51sSupfB");
  const status = document.getElementById("contact-status");

  function showStatus(message, isError) {
    if (!status) return;
    status.textContent = message;
    status.classList.remove(
      "hidden",
      "bg-green-100",
      "text-green-800",
      "dark:bg-green-900/40",
      "dark:text-green-200",
      "bg-red-100",
      "text-red-800",
      "dark:bg-red-900/40",
      "dark:text-red-200",
    );
    if (isError) {
      status.classList.add(
        "bg-red-100",
        "text-red-800",
        "dark:bg-red-900/40",
        "dark:text-red-200",
      );
    } else {
      status.classList.add(
        "bg-green-100",
        "text-green-800",
        "dark:bg-green-900/40",
        "dark:text-green-200",
      );
    }
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]');
    if (submitBtn) submitBtn.disabled = true;

    try {
      const res = await fetch(form.action, {
        method: "POST",
        headers: { Accept: "application/json" },
        body: new FormData(form),
      });
      const json = await res.json();
      if (json.success) {
        showStatus("Thanks! Your message has been sent.", false);
        form.reset();
      } else {
        showStatus(json.message || "Something went wrong. Please try again.", true);
      }
    } catch (err) {
      showStatus("Something went wrong. Please try again.", true);
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
