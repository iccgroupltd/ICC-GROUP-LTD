---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  highlight?: string;
  bgImage?: ImageMetadata;
}

const { title, highlight, bgImage } = Astro.props;

const parts = highlight ? title.split(highlight) : [title];
---

<section
  class:list={[
    "relative flex min-h-[60vh] items-center justify-center overflow-hidden px-4 py-24 md:min-h-[70vh] md:py-32",
    { "bg-base-950": !bgImage },
  ]}
>
  {
    bgImage && (
      <>
        <Picture
          src={bgImage}
          alt=""
          widths={[400, 600, 800, 1000]}
          sizes="(max-width: 767px) 100vw, 0px"
          width={600}
          height={800}
          fit="cover"
          formats={["avif", "webp"]}
          class="absolute inset-0 h-full w-full object-cover md:hidden"
          loading="eager"
          fetchpriority="high"
        />
        <Picture
          src={bgImage}
          alt=""
          widths={[768, 1024, 1280, 1920, 2400]}
          sizes="100vw"
          width={1920}
          height={1080}
          fit="cover"
          formats={["avif", "webp"]}
          class="absolute inset-0 hidden h-full w-full object-cover md:block"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-black/70" />
      </>
    )
  }
  <h1
    class="relative text-center text-4xl leading-tight font-bold uppercase tracking-tight text-white md:text-6xl lg:text-7xl"
  >
    {parts[0]}
    {highlight && <span class:list={[{ "text-primary-200": bgImage, "text-primary-500": !bgImage }]}>{highlight}</span>}
    {parts[1]}
  </h1>
</section>
