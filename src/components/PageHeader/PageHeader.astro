---
interface Props {
  title: string;
  highlight?: string;
}

const { title, highlight } = Astro.props;

const parts = highlight ? title.split(highlight) : [title];
---

<section class="bg-base-950 flex min-h-[60vh] items-center justify-center px-4 py-24 md:min-h-[70vh] md:py-32">
  <h1 class="text-center text-4xl leading-tight font-bold uppercase tracking-tight text-white md:text-6xl lg:text-7xl">
    {parts[0]}
    {highlight && <span class="text-primary-500">{highlight}</span>}
    {parts[1]}
  </h1>
</section>
