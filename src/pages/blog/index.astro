---
// layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import PostCard from "@components/PostCard/PostCardAtlas.astro";
import Badge from "@components/Badge/Badge.astro";
import CollectionPageStructuredData from "@components/structured-data/CollectionPageStructuredData.astro";
import Breadcrumbs from "@components/structured-data/Breadcrumbs.astro";

// utils
import { getAllPosts } from "@js/blogUtils";
import { getLocaleFromUrl } from "@js/localeUtils";

const currLocale = getLocaleFromUrl(Astro.url);
const posts = await getAllPosts(currLocale);
---

<BaseLayout
  title="Our Blog Posts"
  description="Learn from our blog posts about web development, design, and more."
>
  <CollectionPageStructuredData
    slot="structured-data"
    items={posts}
    baseUrl="/blog"
    title="Our Blog Posts"
    description="Learn from our blog posts about web development, design, and more."
  />
  <Breadcrumbs slot="structured-data" items={[{ name: "ICC Taxi Claims", url: "/" }, { name: "Blog", url: "/blog" }]} />
  <section class="site-container">
    <div
      class="overflow-x-clip bg-[url('/assets/pattern-light.svg')] bg-center bg-no-repeat pt-24 md:pt-32 dark:bg-[url('/assets/pattern-dark.svg')]"
    >
      <div class="mx-auto flex max-w-[950px] flex-col justify-center">
        <div class="mx-auto">
          <Badge>Blog</Badge>
        </div>
        <h1 class="h1 text-center">
          Our mission is to make knowledge and news accessible for everyone.
        </h1>
      </div>

    </div>

    <div class="grid gap-8 gap-y-10 md:grid-cols-2">
      {posts.map((post) => <PostCard post={post} showDescription={true} data-mos="fade-up" />)}
    </div>
  </section>
</BaseLayout>